<% content_for :title, "Expenses — #{Date::MONTHNAMES[@month]} #{@year}" %>

<% select_class = "bg-gray-700 border border-gray-600 text-white text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full min-w-[11rem] p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:text-white" %>
<% label_class = "block mb-2 text-sm font-medium text-gray-900 dark:text-white" %>

<div class="space-y-8">
  <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between">
    <h1 class="text-4xl font-bold tracking-tight text-heading md:text-5xl lg:text-3xl">Expenses</h1>
    <%= link_to "Add expense", new_expense_path, class: "text-fg-brand bg-neutral-primary border border-brand hover:bg-brand hover:text-white focus:ring-4 focus:ring-brand-subtle font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none shrink-0" %>
  </div>

  <%= form_with url: expenses_path, method: :get, data: { turbo_frame: "_top" }, class: "block" do %>
    <div class="flex flex-wrap items-end gap-6">
      <div class="w-full sm:w-auto">
        <%= label_tag :year, "Year", class: label_class %>
        <%= select_tag :year, options_for_select(@year_options, @year), onchange: "this.form.requestSubmit()", class: select_class %>
      </div>
      <div class="w-full sm:w-auto">
        <%= label_tag :month, "Month", class: label_class %>
        <%= select_tag :month, options_for_select(month_options_for_select(@year), @month), onchange: "this.form.requestSubmit()", class: select_class %>
      </div>
    </div>
    <noscript><%= submit_tag "Go" %></noscript>
  <% end %>

  <% py, pm = shift_month(@year, @month, -1) %>
  <% ny, nm = shift_month(@year, @month, 1) %>
  <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-center sm:gap-6">
    <p class="text-body flex flex-wrap items-center gap-x-2 gap-y-1">
      <% if previous_period_available?(@year, @month) %>
        <%= link_to "Previous month", expenses_path_for_period(py, pm), class: "hover:underline hover:text-fg-brand font-medium" %>
      <% end %>
      <% if previous_period_available?(@year, @month) && next_period_available?(@year, @month) %>
        <span class="text-body-subtle" aria-hidden="true">·</span>
      <% end %>
      <% if next_period_available?(@year, @month) %>
        <%= link_to "Next month", expenses_path_for_period(ny, nm), class: "hover:underline hover:text-fg-brand font-medium" %>
      <% end %>
    </p>
    <%= button_to "Get expense report", mail_month_to_date_expenses_path(year: @year, month: @month), method: :post, data: { tooltip_target: "tooltip-animation" }, class: "text-fg-brand bg-neutral-primary border border-brand hover:bg-brand hover:text-white focus:ring-4 focus:ring-brand-subtle font-medium leading-5 rounded-base text-sm px-4 py-2.5 focus:outline-none w-full sm:w-auto justify-center cursor-pointer" %>
  </div>

  <div id="tooltip-animation" role="tooltip" class="absolute z-10 invisible inline-block px-3 py-2 text-sm font-medium text-white transition-opacity duration-300 bg-dark rounded-base shadow-xs opacity-0 tooltip">
    Get early expense report from the first of the month to today's date. <br>If month has passed, get report from the first to the end of the previous month.
    <div class="tooltip-arrow" data-popper-arrow></div>
  </div>

  <section class="space-y-3">
    <h2 class="text-xl font-semibold text-heading">Summary</h2>
    <p class="text-body">Total: <strong class="text-fg-brand"><%= number_to_currency(@grand_total) %></strong></p>
    <% if @totals_by_filter.any? %>
      <ul class="list-disc list-inside space-y-1 text-body">
        <% @totals_by_filter.each do |label, amt| %>
          <li><%= label %>: <%= number_to_currency(amt) %></li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-body">No expenses this month.</p>
    <% end %>
  </section>

  <section class="space-y-4">
    <h2 class="text-xl font-semibold text-heading">Entries</h2>

    <% if @expenses.any? %>
      <div class="relative overflow-x-auto bg-neutral-primary-soft shadow-xs rounded-base border border-default">

        <table class="w-full text-sm text-left rtl:text-right text-body">

          <thead class="text-sm text-body bg-neutral-secondary-medium border-b border-default-medium">
            <tr>
              <th class="px-6 py-3 font-medium">Date</th>
              <th class="px-6 py-3 font-medium">Name</th>
              <th class="px-6 py-3 font-medium">Filter</th>
              <th class="px-6 py-3 font-medium">Amount</th>
              <th class="px-6 py-3 font-medium text-right">
                <span class="sr-only">Actions</span>
              </th>
            </tr>
          </thead>

          <tbody>
            <% @expenses.each do |expense| %>
              <tr class="bg-neutral-primary-soft border-b border-default hover:bg-neutral-secondary-medium">

                <td class="px-6 py-4">
                  <%= l expense.spent_on, format: :default %>
                </td>

                <td class="px-6 py-4">
                  <div class="font-medium text-heading">
                    <%= expense.name %>
                  </div>
                  <% if expense.description.present? %>
                    <div class="text-xs text-body mt-1">
                      <%= expense.description %>
                    </div>
                  <% end %>
                </td>

                <td class="px-6 py-4">
                  <%= expense.filter&.name || "—" %>
                </td>

                <td class="px-6 py-4">
                  <%= number_to_currency(expense.amount) %>
                </td>

                <td class="px-6 py-4 text-right space-x-3">
                  <%= link_to "Edit",
                      edit_expense_path(expense),
                      class: "font-medium text-green-500 text-fg-brand hover:underline" %>

                  <%= button_to "Delete",
                      expense_path(expense),
                      method: :delete,
                      form: { data: { turbo_confirm: "Remove this expense?" } },
                      class: "font-medium text-red-500 hover:underline bg-transparent border-none p-0 inline cursor-pointer" %>
                </td>

              </tr>
            <% end %>
          </tbody>

        </table>
      </div>

    <% else %>
      <p class="text-body">
        No expenses for this month.
        <%= link_to "Add one", new_expense_path, class: "text-fg-brand hover:underline" %>.
      </p>
    <% end %>
  </section>
</div>
