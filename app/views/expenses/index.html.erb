<% content_for :title, "Expenses — #{Date::MONTHNAMES[@month]} #{@year}" %>

<div>
  <h1>Expenses</h1>
  <%= link_to "Add expense", new_expense_path %>
</div>

<%= form_with url: expenses_path, method: :get, data: { turbo_frame: "_top" } do %>
  <p>
    <label>Year
      <%= select_tag :year, options_for_select(@year_options, @year), onchange: "this.form.requestSubmit()" %>
    </label>
    <label>Month
      <%= select_tag :month, options_for_select(month_options_for_select, @month), onchange: "this.form.requestSubmit()" %>
    </label>
  </p>
  <noscript><%= submit_tag "Go" %></noscript>
<% end %>

<% py, pm = shift_month(@year, @month, -1) %>
<% ny, nm = shift_month(@year, @month, 1) %>
<p>
  <% if previous_period_available?(@year, @month) %>
    <%= link_to "Previous month", expenses_path_for_period(py, pm) %>
  <% end %>
  <% if previous_period_available?(@year, @month) && next_period_available?(@year, @month) %> · <% end %>
  <% if next_period_available?(@year, @month) %>
    <%= link_to "Next month", expenses_path_for_period(ny, nm) %>
  <% end %>
</p>

<p>
  <%= button_to "Get current expense report (email)", mail_month_to_date_expenses_path(year: @year, month: @month), method: :post %>
</p>
<p><small>Sends a PDF to your address for <%= Date::MONTHNAMES[@month] %> <%= @year %>, from the 1st through today (or through the end of that month if it is already past).</small></p>

<section>
  <h2>Summary</h2>
  <p>Total <strong><%= number_to_currency(@grand_total) %></strong></p>
  <% if @totals_by_filter.any? %>
    <ul>
      <% @totals_by_filter.each do |label, amt| %>
        <li><%= label %>: <%= number_to_currency(amt) %></li>
      <% end %>
    </ul>
  <% else %>
    <p>No expenses this month.</p>
  <% end %>
</section>

<section>
  <h2>Entries</h2>
  <% if @expenses.any? %>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Name</th>
          <th>Filter</th>
          <th>Amount</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @expenses.each do |expense| %>
          <tr>
            <td><%= l expense.spent_on, format: :default %></td>
            <td>
              <%= expense.name %>
              <% if expense.description.present? %>
                <div><small><%= expense.description %></small></div>
              <% end %>
            </td>
            <td><%= expense.filter&.name || "—" %></td>
            <td><%= number_to_currency(expense.amount) %></td>
            <td>
              <%= link_to "Edit", edit_expense_path(expense) %>
              <%= button_to "Delete", expense_path(expense), method: :delete, form: { data: { turbo_confirm: "Remove this expense?" } } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No expenses for this month. <%= link_to "Add one", new_expense_path %>.</p>
  <% end %>
</section>
